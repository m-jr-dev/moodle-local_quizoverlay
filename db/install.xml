<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/quizoverlay/db" VERSION="2026030300" COMMENT="Quiz override tables"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">

    <TABLES>

        <TABLE NAME="local_quizoverlay_upass" COMMENT="Senha por usuário (mesma senha para todas as provas do aluno)">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="ID do usuário"/>
                <FIELD NAME="password" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="" COMMENT="Senha do aluno"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="user_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="userid_uix" UNIQUE="true" FIELDS="userid"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="local_quizoverlay" COMMENT="Sobreposições de quiz por aluno/curso">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="ID do usuário"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="ID do curso"/>
                <FIELD NAME="timeopen" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Data/hora inicial (timestamp)"/>
                <FIELD NAME="timeclose" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Data/hora final (timestamp)"/>
                <FIELD NAME="quiz" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="" COMMENT="Nome do quiz"/>
                <FIELD NAME="attempts" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Tentativas (0 = ilimitado)"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="user_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="course_fk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
                <INDEX NAME="timeopen_idx" UNIQUE="false" FIELDS="timeopen"/>
                <INDEX NAME="uniq_overlay" UNIQUE="true" FIELDS="userid,courseid,timeopen,timeclose,quiz"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>
